{
  "appId": "com.mafialocal.app",
  "productName": "Mafia Local",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.cjs",
    "package.json",
    "assets/**/*",
    "ui/**/*",
    {
      "from": "../Server/dist",
      "to": "Server/dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "extraResources": [
    {
      "from": "../Client/dist",
      "to": "Client/dist",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "assets/Mafia-Icon-256x256.ico",
      "to": "Mafia-Icon.ico"
    }
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "signAndEditExecutable": false,
    "icon": "assets/Mafia-Icon-256x256.ico"
  },
  "nsis": {
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "Mafia Local",
    "installerIcon": "assets/Mafia-Icon-256x256.ico",
    "uninstallerIcon": "assets/Mafia-Icon-256x256.ico",
    "installerHeaderIcon": "assets/Mafia-Icon-256x256.ico",
    "include": "installer.nsh"
  }
}
