{
  "appId": "com.mafialocal.app",
  "productName": "Mafia Local",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "package.json",
    "assets/**/*",
    {
      "from": "../Server/dist",
      "to": "Server/dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "extraResources": [
    {
      "from": "../Client/dist",
      "to": "Client/dist",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": [
      "nsis"
    ],
    "signAndEditExecutable": false
  }
}
