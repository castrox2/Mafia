{
  "name": "mafia-local-electron",
  "version": "1.0.0",
  "description": "Electron desktop host wrapper for the Mafia local-first party game",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:client": "npm --prefix ../Client run build",
    "build:server": "npm --prefix ../Server run build",
    "build": "npm run build:client && npm run build:server",
    "dist": "npm run build && electron-builder --config electron-builder.json",
    "dist:dir": "npm run build && electron-builder --dir --config electron-builder.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "electron": "^41.0.2",
    "electron-builder": "^26.4.0",
    "typescript": "^5.9.3"
  }
}
